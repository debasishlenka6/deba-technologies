# ── DATABASE ─────────────────────────────────────
# PostgreSQL connection settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=deba_technologies
DB_USER=postgres
DB_PASSWORD=your_strong_password_here
DB_SSL=false

# ── API ───────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS ─────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5500

# ── EMAIL (Gmail SMTP — FREE) ────────────────────
# Step 1: Enable 2FA on your Gmail account
# Step 2: Go to Gmail → Settings → Security → App passwords
# Step 3: Create app password for "Mail" → copy the 16-char code
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Email that receives order notifications
# Notifications go to your GMAIL_USER by default
# Or set a different personal email here
NOTIFY_EMAIL=
